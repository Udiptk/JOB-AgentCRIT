# ── Autonomous Job Application System — Environment Variables ──
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# SQLite (default for local dev)
DATABASE_URL=sqlite:///./job_bot.db

# Google Gemini API Key — get yours at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Serper.dev API Key — get yours at https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# JWT Secret — use a long random string in production
SECRET_KEY=change-this-to-a-long-random-secret
